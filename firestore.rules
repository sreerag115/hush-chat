// Firestore Security Rules for WhisperChat
// Paste these in: Firebase Console → Firestore → Rules tab

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Contacts sub-collection: any authenticated user can write to another user's contacts
      // (needed for bidirectional key exchange on friend accept)
      match /contacts/{contactId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null;
      }
    }

    // Friend requests: sender can create, recipient can read/update/delete
    match /friend_requests/{reqId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
    }

    // Connections: only members can read
    match /connections/{connId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
    }

    // Conversations: only the two participants can read/write messages
    match /conversations/{convId} {
      match /messages/{msgId} {
        allow read, write: if request.auth != null
                           && (resource.data.senderUid == request.auth.uid
                               || resource.data.receiverUid == request.auth.uid);
        allow create: if request.auth != null
                      && request.resource.data.senderUid == request.auth.uid;
      }
    }

    // Call signaling: any authenticated user can send signals to others
    match /calls/{callId} {
      match /signals/{signalId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
